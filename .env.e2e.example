# Dedicated env file for the end-to-end Playwright pipeline.
# Loaded by `scripts/ci-e2e.sh` via `docker compose --env-file .env.e2e ...`.
# Values must be self-consistent with docker-compose.prod.yml so that a fresh
# checkout can run `./scripts/ci-e2e.sh` without a hand-written .env.

TRAEFIK_BIND_PORT=3080
DATABASE_URL=postgresql://chat:chat@db:5432/chat?schema=public

CENTRIFUGO_TOKEN_HMAC_SECRET=e2e-centrifugo-hmac-secret-000000
CENTRIFUGO_API_KEY=e2e-centrifugo-api-key
CENTRIFUGO_URL=http://centrifugo:3080
NEXT_PUBLIC_CENTRIFUGO_WS_URL=ws://localhost:3080/connection/websocket
CENTRIFUGO_CLIENT_ALLOWED_ORIGINS="http://localhost:3080 http://127.0.0.1:3080"

SESSION_SECRET=e2e-session-secret-0000000000000000000000
SESSION_COOKIE_DOMAIN=
UPLOADS_DIR=/app/uploads
PASSWORD_RESET_DELIVERY_FILE=/app/uploads/password-reset-deliveries.log
LOG_LEVEL=info
E2E_FAKE_TIME=1
