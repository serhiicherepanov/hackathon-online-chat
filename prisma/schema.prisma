// Prisma schema — R0 chat (users, sessions, rooms, DMs, messages, reads).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConversationType {
  room
  dm
}

enum RoomVisibility {
  public
  private
}

enum RoomMemberRole {
  owner
  admin
  member
}

enum RoomInviteStatus {
  pending
  accepted
  declined
}

enum FriendshipStatus {
  pending
  accepted
}

enum PresenceStatus {
  online
  afk
  offline
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  sessions       Session[]
  roomMembers    RoomMember[]
  roomInvites    RoomInvite[]   @relation("RoomInvitee")
  roomInvitesSent RoomInvite[]  @relation("RoomInviter")
  roomBans       RoomBan[]
  roomBansIssued RoomBan[]      @relation("RoomBannedBy")
  dmParticipants DmParticipant[]
  messages       Message[]
  messageReads   MessageRead[]
  attachments    Attachment[]
  friendshipsA   Friendship[]   @relation("FriendshipUserA")
  friendshipsB   Friendship[]   @relation("FriendshipUserB")
  sentRequests   Friendship[]   @relation("FriendshipRequestedBy")
  blocksSent     UserBlock[]    @relation("UserBlocker")
  blocksReceived UserBlock[]    @relation("UserBlocked")
  presence       Presence?
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  userAgent  String?
  ip         String?
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
}

model Conversation {
  id        String           @id @default(cuid())
  type      ConversationType
  dmKey     String?          @unique
  createdAt DateTime         @default(now())

  room           Room?
  messages       Message[]
  messageReads   MessageRead[]
  dmParticipants DmParticipant[]
}

model Room {
  id             String         @id @default(cuid())
  conversationId String         @unique
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  name           String         @unique
  description    String?
  visibility     RoomVisibility @default(public)

  members RoomMember[]
  invites RoomInvite[]
  bans    RoomBan[]
}

model RoomMember {
  id       String         @id @default(cuid())
  roomId   String
  room     Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId   String
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     RoomMemberRole @default(member)
  joinedAt DateTime       @default(now())

  @@unique([roomId, userId])
  @@index([roomId, role])
  @@index([userId])
}

model RoomInvite {
  id          String           @id @default(cuid())
  roomId       String
  room         Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  inviteeId    String
  invitee      User             @relation("RoomInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)
  inviterId    String
  inviter      User             @relation("RoomInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  status       RoomInviteStatus @default(pending)
  createdAt    DateTime         @default(now())
  respondedAt  DateTime?

  @@index([roomId, status])
  @@index([inviteeId, status, createdAt])
  @@index([inviterId, createdAt])
}

model RoomBan {
  id          String   @id @default(cuid())
  roomId       String
  room         Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bannedById   String
  bannedBy     User     @relation("RoomBannedBy", fields: [bannedById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([roomId, userId])
  @@index([userId, createdAt])
  @@index([bannedById, createdAt])
}

model DmParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Friendship {
  id            String           @id @default(cuid())
  userAId       String
  userA         User             @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId       String
  userB         User             @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)
  status        FriendshipStatus @default(pending)
  requestedById String
  requestedBy   User             @relation("FriendshipRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  note          String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([userAId, userBId])
  @@index([requestedById, status])
  @@index([status, updatedAt])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("UserBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("UserBlocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model Presence {
  userId       String         @id
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       PresenceStatus @default(offline)
  lastActiveAt DateTime       @default(now())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, lastActiveAt])
}

model Message {
  id             String       @id
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId       String
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime     @default(now())
  editedAt       DateTime?
  deletedAt      DateTime?
  replyToId      String?
  replyTo        Message?     @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        Message[]    @relation("MessageReplies")
  attachments    Attachment[]

  @@index([conversationId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([replyToId])
}

enum AttachmentKind {
  image
  file
}

model Attachment {
  id           String         @id @default(cuid())
  uploaderId   String
  uploader     User           @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  messageId    String?
  message      Message?       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  originalName String
  storedPath   String
  mime         String
  size         Int
  kind         AttachmentKind
  comment      String?
  createdAt    DateTime       @default(now())

  @@index([messageId])
  @@index([uploaderId, createdAt])
}

model MessageRead {
  conversationId    String
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadMessageId String

  @@id([conversationId, userId])
  @@index([userId])
}
