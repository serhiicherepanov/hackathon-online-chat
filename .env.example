# Copy this file to .env and adjust if needed. Defaults work for `docker compose up`.

# Host port that Traefik binds. Every other service stays unpublished and is
# reached through Traefik on this port (or via the compose internal network).
TRAEFIK_BIND_PORT=3080

# ─────────────────────────────────────────────────────────────────────────────
# Database Backend Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Choose your database backend: "local" (Docker PostgreSQL) or "neon" (Neon Serverless)
# Default: local
DB_BACKEND=local

# PostgreSQL connection string used by Prisma.
# For local Docker: postgresql://chat:chat@db:5432/chat?schema=public
# For Neon: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://chat:chat@db:5432/chat?schema=public

# Shared HMAC secret used to sign Centrifugo connection tokens (server + centrifugo config).
CENTRIFUGO_TOKEN_HMAC_SECRET=dev-centrifugo-hmac-secret-change-me

# Admin HTTP API key for server-to-Centrifugo calls (publish, unsubscribe, etc.).
CENTRIFUGO_API_KEY=dev-centrifugo-api-key-change-me

# HTTP API base URL used by the Next.js server for Centrifugo admin calls (publish,
# presence, health). In Compose this is the internal service (port must match
# centrifugo/config.json). If Centrifugo is only reachable via Traefik on a public
# host—typical when Next.js is deployed separately—set this to that base, including
# any path prefix (no trailing slash required), e.g.
#   https://chat.example.com/realtime
CENTRIFUGO_URL=http://centrifugo:3080

# WebSocket URL used by the browser. Goes through Traefik on TRAEFIK_BIND_PORT.
NEXT_PUBLIC_CENTRIFUGO_WS_URL=ws://localhost:3080/connection/websocket

# Origin header allowlist for the Centrifugo WebSocket endpoint. Space-separated
# list of origins (scheme+host+port, no trailing slash). The browser's Origin
# must appear here or Centrifugo rejects the upgrade with "Origin not authorized".
# In production this must include the public HTTPS origin, e.g.:
#   CENTRIFUGO_CLIENT_ALLOWED_ORIGINS=https://webchat.example.com
CENTRIFUGO_CLIENT_ALLOWED_ORIGINS=http://localhost:3080 http://127.0.0.1:3080

# Secret used by Next.js to sign session cookies (populated in R0 auth change).
SESSION_SECRET=dev-session-secret-change-me-32chars!!

# Optional cookie domain for sharing auth across subdomains, e.g.
# `.digitalspace.studio`. Leave empty to keep the cookie host-only.
SESSION_COOKIE_DOMAIN=

# Local filesystem directory where uploaded files will be stored (reserved for R1).
UPLOADS_DIR=/app/uploads

# Optional dev/test artifact file for password-reset deliveries. When set, reset
# requests append JSON lines containing the email and reset URL here.
PASSWORD_RESET_DELIVERY_FILE=/app/uploads/password-reset-deliveries.log

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# Web Push / VAPID (desktop notifications)
# ─────────────────────────────────────────────────────────────────────────────
# These are a throwaway *dev* keypair committed only to let `docker compose up`
# boot out of the box. Regenerate for any shared / staging / production
# environment with: `docker compose exec app pnpm tsx scripts/gen-vapid.ts`.
# The public key is exposed to the browser (safe by design — VAPID public half).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BGhYo-DnOzL7Oab7eLvYGkW7q7IoCqr7FgFZmyqyZEE9J0dTzXiS1VZbXwCyUvbwCO_b0a9TqAZhxoAOpA_eQ1A
VAPID_PRIVATE_KEY=kS5hU5uqpOdsMAjVAOLFD5WXu9oWTuu5k7SSkrANgaw
# RFC-8292 requires a `mailto:` or HTTPS URI identifying the push sender.
VAPID_SUBJECT=mailto:dev@localhost
